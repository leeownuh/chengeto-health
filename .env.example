# Root environment template (used by docker compose)
# Copy to `.env` and fill values as needed.

# Mongo / Redis
MONGO_PASSWORD=chengeto_secure_2024
REDIS_PASSWORD=chengeto_redis_2024

# Auth / crypto
JWT_SECRET=change_me_jwt_secret_min_32_chars
REFRESH_TOKEN_SECRET=change_me_refresh_secret
ENCRYPTION_KEY=change_me_32_chars_exactly________

# App
NODE_ENV=production

# CORS (comma-separated origins)
# Examples:
# CORS_ORIGIN=http://localhost,http://127.0.0.1
# CORS_ORIGIN=https://chengeto.health
CORS_ORIGIN=http://localhost,http://127.0.0.1

# MQTT
MQTT_PORT=1883
MQTT_WS_PORT=8083
# Demo auth accepts any non-empty username/password (simulators).
MQTT_DEMO_AUTH=true

# Frontend runtime URLs (Vite)
VITE_API_URL=http://localhost:5000/api/v1
VITE_SOCKET_URL=http://localhost:5000

# Optional integrations (leave blank for demo)
CONTRACT_ADDRESS=
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=
SMTP_USER=
SMTP_PASS=

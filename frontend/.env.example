# Frontend (Vite) environment template
# Copy to `.env` for local dev or set these as build-time env vars in your hosting provider.

# Backend API base URL (must include `/api/v1`).
VITE_API_URL=http://localhost:5000/api/v1

# Backend Socket.IO base URL (no path).
VITE_SOCKET_URL=http://localhost:5000

# Optional: override backend port for local runtime URL helpers.
VITE_BACKEND_PORT=5000


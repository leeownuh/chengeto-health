{
  "title": "CHENGETO Health Overview",
  "tags": ["chengeto", "health", "overview"],
  "timezone": "browser",
  "schemaVersion": 16,
  "version": 1,
  "refresh": "30s",
  "panels": [
    {
      "id": 1,
      "title": "Total Patients",
      "type": "stat",
      "gridPos": { "h": 4, "w": 4, "x": 0, "y": 0 },
      "targets": [
        {
          "expr": "chengeto_patients_total",
          "legendFormat": "Total Patients"
        }
      ],
      "options": {
        "colorMode": "value",
        "graphMode": "area"
      }
    },
    {
      "id": 2,
      "title": "Active Alerts",
      "type": "stat",
      "gridPos": { "h": 4, "w": 4, "x": 4, "y": 0 },
      "targets": [
        {
          "expr": "chengeto_alerts_active",
          "legendFormat": "Active Alerts"
        }
      ],
      "options": {
        "colorMode": "value",
        "graphMode": "area"
      },
      "fieldConfig": {
        "thresholds": {
          "mode": "absolute",
          "steps": [
            { "value": 0, "color": "green" },
            { "value": 5, "color": "yellow" },
            { "value": 10, "color": "red" }
          ]
        }
      }
    },
    {
      "id": 3,
      "title": "Check-ins Today",
      "type": "stat",
      "gridPos": { "h": 4, "w": 4, "x": 8, "y": 0 },
      "targets": [
        {
          "expr": "chengeto_checkins_today",
          "legendFormat": "Check-ins"
        }
      ],
      "options": {
        "colorMode": "value",
        "graphMode": "area"
      }
    }
  ]
}


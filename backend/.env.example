# Server Configuration
NODE_ENV=development
PORT=5000
HOST=localhost

# MongoDB Configuration
MONGODB_URI=mongodb://localhost:27017/chengeto_health
MONGODB_USER=admin
MONGODB_PASSWORD=admin123

# JWT Configuration
JWT_SECRET=your-super-secret-jwt-key-change-in-production-min-256-bits
JWT_EXPIRES_IN=8h
JWT_REFRESH_EXPIRES_IN=7d
JWT_ADMIN_EXPIRES_IN=1h

# Encryption Keys
AES_ENCRYPTION_KEY=your-256-bit-aes-encryption-key-here-32-chars!
PBKDF2_ITERATIONS=100000

# MQTT Configuration
MQTT_PORT=1883
MQTT_WS_PORT=8083
MQTT_HOST=localhost

# Blockchain Configuration
BLOCKCHAIN_RPC_URL=http://localhost:8545
BLOCKCHAIN_PRIVATE_KEY=0x-your-private-key-here
BLOCKCHAIN_CONTRACT_ADDRESS=

# Push Notification (VAPID Keys)
VAPID_PUBLIC_KEY=your-vapid-public-key
VAPID_PRIVATE_KEY=your-vapid-private-key
VAPID_SUBJECT=mailto:contact@chengeto.health

# SMS Gateway Configuration (Africa's Talking)
SMS_API_KEY=your-africas-talking-api-key
SMS_USERNAME=your-username
SMS_SENDER_ID=CHENGETO

# Rate Limiting
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX_REQUESTS=100

# CORS Configuration
CORS_ORIGIN=http://localhost:5173

# Logging
LOG_LEVEL=info
LOG_FILE=logs/chengeto.log

# MFA Configuration
MFA_ISSUER=CHENGETO-Health
MFA_SECRET_LENGTH=32

# IoT Device Configuration
IOT_HEARTBEAT_INTERVAL=30000
IOT_OFFLINE_THRESHOLD=120000

# Alert Escalation Timeouts (minutes)
ESCALATION_LEVEL1_TIMEOUT=5
ESCALATION_LEVEL2_TIMEOUT=10
ESCALATION_LEVEL3_TIMEOUT=15

# Vital Sign Thresholds
HEART_RATE_MIN=50
HEART_RATE_MAX=120
INACTIVITY_THRESHOLD_HOURS=4